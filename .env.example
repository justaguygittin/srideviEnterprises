# =========================================================
# Project : Sridevi Enterprises
# File    : .env.example
# Purpose : Template for the environment variables config.py
#           loads via python-dotenv. Copy this to .env and
#           fill in real values. Never commit the real .env.
# =========================================================

# Database connection (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Flask session/signing secret. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Must be "False" in production. Only set to "True" for local development.
FLASK_DEBUG=False
